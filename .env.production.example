# Hospital Appointment System - Production Environment Configuration
# Instructions: Use this file as a template for production deployments
# Replace placeholder values with actual production values

# Database Configuration
SPRING_DATASOURCE_URL=jdbc:postgresql://your-postgres-host:5432/hospital_db
SPRING_DATASOURCE_USERNAME=production_user
SPRING_DATASOURCE_PASSWORD=strong_database_password_here

# JWT Configuration (IMPORTANT: Generate a strong random secret)
JWT_SECRET=your_very_long_random_secret_key_at_least_32_characters_long
JWT_EXPIRATION=86400000

# Server Configuration
SERVER_PORT=8080
SPRING_JPA_HIBERNATE_DDL_AUTO=validate

# CORS Configuration
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Logging
LOGGING_LEVEL_COM_EXAMPLE_HOSPITAL=INFO
LOGGING_LEVEL_ROOT=WARN
